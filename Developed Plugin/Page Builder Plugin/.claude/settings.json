{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "TodoWrite",
      "Task",
      "Agent",
      "NotebookEdit"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(sudo rm*)"
    ]
  },
  "env": {
    "PROJECT_NAME": "MariMail",
    "PROJECT_TYPE": "marine-email-intelligence-platform",
    "AUTOPILOT_MODE": "true"
  },
  "model": "claude-opus-4-7"
}
